{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/(.*\\.css)", "dest": "/$1" },
    { "src": "/(.*\\.js)", "dest": "/$1" },
    { "src": "/(.*\\.png|.*\\.jpg|.*\\.ico|.*\\.svg)", "dest": "/$1" },
    { "src": "/", "dest": "/auth.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
